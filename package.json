{
  "name": "askchokro",
  "private": true,
  "description": "The open-source AI Data Engine for Node.js — secure, provider-agnostic natural-language interfaces for SQL databases.",
  "license": "MIT",
  "author": "Digital Chokro <hello@digitalchokro.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalchokro/askchokro.git"
  },
  "homepage": "https://github.com/digitalchokro/askchokro",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/minimatch": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "tsx": "^4.23.1",
    "turbo": "^2.10.2"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:security": "vitest run packages/core/src/__tests__/security/",
    "eval": "tsx eval/runner.ts",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "keywords": [
    "askchokro",
    "sql",
    "ai",
    "llm",
    "text-to-sql",
    "nlp",
    "rag",
    "database",
    "analytics",
    "business intelligence",
    "agent",
    "generative ai",
    "typescript",
    "node.js"
  ],
  "resolutions": {
    "cross-spawn": ">=7.0.6",
    "postcss": ">=8.5.1",
    "vite": ">=6.4.3",
    "esbuild": ">=0.28.1",
    "vitest": ">=3.2.6"
  }
}