{
  "name": "@digitalchokro/microservice",
  "version": "1.1.5",
  "description": "Standalone Dockerized microservice for AskChokro (for WordPress and other platforms).",
  "license": "MIT",
  "author": "Digital Chokro <hello@digitalchokro.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalchokro/askchokro.git",
    "directory": "packages/microservice"
  },
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts --sourcemap",
    "build": "tsup src/index.ts --format esm --sourcemap",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@digitalchokro/adapter-express": "workspace:*",
    "@digitalchokro/askchokro": "workspace:*",
    "@digitalchokro/db-mysql": "workspace:*",
    "@digitalchokro/db-postgres": "workspace:*",
    "@digitalchokro/db-sqlite": "workspace:*",
    "@digitalchokro/provider-anthropic": "workspace:*",
    "@digitalchokro/provider-gemini": "workspace:*",
    "@digitalchokro/provider-ollama": "workspace:*",
    "@digitalchokro/provider-openai": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "askchokro",
    "sql",
    "ai",
    "llm",
    "text-to-sql",
    "nlp",
    "rag",
    "database",
    "analytics",
    "business intelligence",
    "agent",
    "generative ai",
    "typescript",
    "node.js"
  ],
  "publishConfig": {
    "access": "public"
  }
}