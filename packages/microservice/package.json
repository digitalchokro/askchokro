{
  "name": "@digitalchokro/microservice",
  "version": "1.1.0",
  "description": "Standalone Dockerized microservice for AskChokro (for WordPress and other platforms).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@digitalchokro/adapter-express": "workspace:*",
    "@digitalchokro/askchokro": "workspace:*",
    "@digitalchokro/db-mysql": "workspace:*",
    "@digitalchokro/db-postgres": "workspace:*",
    "@digitalchokro/db-sqlite": "workspace:*",
    "@digitalchokro/provider-anthropic": "workspace:*",
    "@digitalchokro/provider-gemini": "workspace:*",
    "@digitalchokro/provider-ollama": "workspace:*",
    "@digitalchokro/provider-openai": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "tsup": "^8.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "askchokro",
    "sql",
    "ai",
    "llm",
    "text-to-sql",
    "nlp",
    "rag",
    "database",
    "analytics",
    "business intelligence",
    "agent",
    "generative ai",
    "typescript",
    "node.js"
  ]
}
