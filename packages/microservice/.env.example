# ==========================================
# ASKCHOKRO MICROSERVICE CONFIGURATION
# ==========================================
# Copy this file to .env and configure your environment variables.

# The port the microservice will listen on
PORT=3000

# ==========================================
# 1. DATABASE CONFIGURATION
# ==========================================
# The WordPress MySQL Database connection string.
# Example: mysql://user:password@host:3306/database
DATABASE_URL=mysql://root:password@host.docker.internal:3306/wordpress

# ==========================================
# 2. AI PROVIDER CONFIGURATION
# ==========================================
# You must provide at least one AI Provider Key (OpenAI, Anthropic, or Gemini)
# The engine will auto-detect which one is set.

# OpenAI API Key (gpt-4o, gpt-3.5-turbo, etc.)
# OPENAI_API_KEY=sk-your-openai-key

# Anthropic API Key (claude-3-5-sonnet, etc.)
# ANTHROPIC_API_KEY=your-anthropic-key

# Google Gemini API Key (gemini-1.5-pro, etc.)
# GEMINI_API_KEY=your-gemini-key

# (Optional) If you are using a local Ollama instance instead of cloud APIs:
# ASKCHOKRO_PROVIDER=ollama
# ASKCHOKRO_MODEL=qwen2.5-coder
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ==========================================
# 3. SECURITY & AUTHENTICATION
# ==========================================
# JWT Secret (MUST match the secret configured in your AskChokro WordPress Plugin)
# To generate a strong secret securely run: `openssl rand -base64 32`
JWT_SECRET=your-very-secure-jwt-secret-here

# ==========================================
# 4. MULTI-VENDOR / TENANT ISOLATION
# ==========================================
# For multi-vendor setups (e.g. Dokan, WCFM), enable this to isolate data per-vendor.
# When true, AskChokro will strictly inject `WHERE <TENANT_COLUMN> = <wp_user_id>` into ALL SQL queries.
ENABLE_TENANT_SCOPING=false
TENANT_COLUMN=post_author
