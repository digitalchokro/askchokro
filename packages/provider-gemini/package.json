{
  "name": "@digitalchokro/provider-gemini",
  "version": "1.0.4",
  "description": "Google Gemini AI provider for AskChokro using @google/genai",
  "author": "digitalchokro",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@digitalchokro/core": "workspace:*",
    "@google/genai": "^2.10.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "askchokro",
    "sql",
    "ai",
    "llm",
    "text-to-sql",
    "nlp",
    "rag",
    "database",
    "analytics",
    "business intelligence",
    "agent",
    "generative ai",
    "typescript",
    "node.js"
  ]
}
