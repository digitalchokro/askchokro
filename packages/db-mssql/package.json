{
  "name": "@digitalchokro/db-mssql",
  "version": "1.0.0",
  "description": "Microsoft SQL Server adapter for AskChokro.",
  "license": "MIT",
  "author": "Digital Chokro <hello@digitalchokro.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalchokro/askchokro.git",
    "directory": "packages/db-mssql"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch --sourcemap",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@digitalchokro/core": "workspace:*",
    "mssql": "^11.0.0"
  },
  "devDependencies": {
    "@digitalchokro/core": "workspace:*",
    "@types/mssql": "^9.1.0",
    "mssql": "^11.0.1",
    "tsup": "^8.0.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "askchokro",
    "sql",
    "ai",
    "llm",
    "text-to-sql",
    "mssql",
    "sqlserver",
    "microsoft",
    "database",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  }
}
