{
  "name": "@digitalchokro/db-sqlite",
  "version": "2.0.3",
  "description": "SQLite adapter for AskChokro. Enables instant local demos with zero database setup.",
  "license": "MIT",
  "author": "Digital Chokro <hello@digitalchokro.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalchokro/askchokro.git",
    "directory": "packages/db-sqlite"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch --sourcemap",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@digitalchokro/core": "workspace:*",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@digitalchokro/core": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "askchokro",
    "sql",
    "ai",
    "llm",
    "text-to-sql",
    "nlp",
    "rag",
    "database",
    "analytics",
    "business intelligence",
    "agent",
    "generative ai",
    "typescript",
    "node.js"
  ],
  "publishConfig": {
    "access": "public"
  }
}