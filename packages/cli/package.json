{
  "name": "@digitalchokro/cli",
  "version": "1.0.5",
  "description": "CLI tool for AskChokro. Run `npx askchokro demo` for an instant local demo.",
  "license": "MIT",
  "author": "Digital Chokro <hello@digitalchokro.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalchokro/askchokro.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "askchokro": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@digitalchokro/adapter-express": "workspace:^",
    "@digitalchokro/core": "workspace:*",
    "@digitalchokro/db-sqlite": "workspace:*",
    "@digitalchokro/provider-ollama": "workspace:*",
    "express": "^5.0.0",
    "open": "^11.0.0",
    "@digitalchokro/askchokro": "workspace:^"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "askchokro",
    "sql",
    "ai",
    "llm",
    "text-to-sql",
    "nlp",
    "rag",
    "database",
    "analytics",
    "business intelligence",
    "agent",
    "generative ai",
    "typescript",
    "node.js"
  ],
  "publishConfig": {
    "access": "public"
  }
}
