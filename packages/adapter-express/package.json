{
  "name": "@askchokro/adapter-express",
  "version": "1.0.0",
  "description": "Express.js middleware adapter for AskChokro. One-liner integration.",
  "license": "MIT",
  "author": "Digital Chokro <hello@digitalchokro.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalchokro/askchokro.git",
    "directory": "packages/adapter-express"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@askchokro/core": "workspace:*",
    "express": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@askchokro/core": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "express": "^5.0.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "askchokro",
    "express",
    "middleware",
    "adapter"
  ],
  "publishConfig": {
    "access": "public"
  }
}
