{
  "name": "askchokro",
  "version": "1.0.0",
  "description": "Zero-config convenience wrapper for AskChokro. Secure, provider-agnostic natural-language to SQL.",
  "license": "MIT",
  "author": "Digital Chokro <hello@digitalchokro.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalchokro/askchokro.git",
    "directory": "packages/askchokro"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@askchokro/core": "workspace:*",
    "@askchokro/db-postgres": "workspace:*",
    "@askchokro/db-sqlite": "workspace:*",
    "@askchokro/provider-ollama": "workspace:*",
    "@askchokro/provider-openai": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ai",
    "sql",
    "text-to-sql",
    "natural-language",
    "database",
    "llm",
    "ollama",
    "openai",
    "postgres",
    "sqlite",
    "askchokro"
  ]
}
