{
  "name": "@digitalchokro/askchokro",
  "version": "2.0.6",
  "description": "Zero-config convenience wrapper for AskChokro. Secure, provider-agnostic natural-language to SQL.",
  "license": "MIT",
  "author": "Digital Chokro <hello@digitalchokro.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalchokro/askchokro.git",
    "directory": "packages/askchokro"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch --sourcemap",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@digitalchokro/core": "workspace:*",
    "@digitalchokro/db-postgres": "workspace:*",
    "@digitalchokro/db-mysql": "workspace:*",
    "@digitalchokro/db-sqlite": "workspace:*",
    "@digitalchokro/provider-anthropic": "workspace:*",
    "@digitalchokro/provider-groq": "workspace:*",
    "@digitalchokro/provider-ollama": "workspace:*",
    "@digitalchokro/provider-openai": "workspace:*",
    "@digitalchokro/provider-gemini": "workspace:*",
    "@digitalchokro/vector-memory": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@digitalchokro/db-postgres": {
      "optional": true
    },
    "@digitalchokro/db-mysql": {
      "optional": true
    },
    "@digitalchokro/db-sqlite": {
      "optional": true
    },
    "@digitalchokro/provider-anthropic": {
      "optional": true
    },
    "@digitalchokro/provider-groq": {
      "optional": true
    },
    "@digitalchokro/provider-ollama": {
      "optional": true
    },
    "@digitalchokro/provider-openai": {
      "optional": true
    },
    "@digitalchokro/provider-gemini": {
      "optional": true
    },
    "@digitalchokro/vector-memory": {
      "optional": true
    }
  },
  "devDependencies": {
    "@digitalchokro/db-postgres": "workspace:*",
    "@digitalchokro/db-mysql": "workspace:*",
    "@digitalchokro/db-sqlite": "workspace:*",
    "@digitalchokro/provider-anthropic": "workspace:*",
    "@digitalchokro/provider-groq": "workspace:*",
    "@digitalchokro/provider-gemini": "workspace:*",
    "@digitalchokro/provider-ollama": "workspace:*",
    "@digitalchokro/provider-openai": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "askchokro",
    "sql",
    "ai",
    "llm",
    "text-to-sql",
    "nlp",
    "rag",
    "database",
    "analytics",
    "business intelligence",
    "agent",
    "generative ai",
    "typescript",
    "node.js"
  ],
  "publishConfig": {
    "access": "public"
  }
}